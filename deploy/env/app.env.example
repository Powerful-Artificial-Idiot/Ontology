NODE_ENV=production

MKG_AGENT_API_HOST=127.0.0.1
MKG_AGENT_API_PORT=4175
MKG_DATA_DIR=/var/lib/manufacturing-graph-explorer

MKG_LLM_PROVIDER=deepseek
MKG_DEEPSEEK_API_KEY=
MKG_DEEPSEEK_MODEL=deepseek-v4-flash
MKG_DEEPSEEK_ANSWER_MODEL=deepseek-v4-flash
MKG_DEEPSEEK_BASE_URL=https://api.deepseek.com
MKG_AGENT_SEMANTIC_PARSER_MODE=llm
MKG_AGENT_ANSWER_COMPOSER_MODE=llm
MKG_LLM_TIMEOUT_MS=20000
MKG_LLM_ANSWER_TIMEOUT_MS=30000

MKG_AGENT_KNOWLEDGE_MODE=neo4j
MKG_NEO4J_URI=bolt://127.0.0.1:7687
MKG_NEO4J_USERNAME=neo4j
MKG_NEO4J_PASSWORD=
MKG_NEO4J_DATABASE=neo4j

MKG_AGENT_DOCUMENT_MODE=governed
MKG_AGENT_STORE_MODE=file
MKG_AGENT_TELEMETRY_MODE=jsonl
MKG_AGENT_RUN_TIMEOUT_MS=60000

MKG_AGENT_SECURITY_PROFILE=production
MKG_AGENT_AUTH_MODE=static-bearer
MKG_AGENT_AUTH_STATIC_TOKEN=
MKG_AGENT_AUTH_PRINCIPAL_ID=manufacturing-agent-api
MKG_AGENT_AUTH_TENANT_ID=demo-manufacturing
MKG_AGENT_AUTH_ROLE_IDS=agent-admin,agent-evidence-reader
MKG_AGENT_AUTH_DOMAIN_IDS=quality,production,manufacturing,engineering,value-stream
MKG_AGENT_AUTH_OBJECT_IDS=
