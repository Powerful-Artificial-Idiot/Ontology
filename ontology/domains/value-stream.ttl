@prefix core: <https://example.com/mkg/core#> .
@prefix mfg: <https://example.com/mkg/manufacturing#> .
@prefix vs: <https://example.com/mkg/value-stream#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/mkg/value-stream> a owl:Ontology ;
  owl:imports <https://example.com/mkg/core>, <https://example.com/mkg/manufacturing> ;
  owl:versionIRI <https://example.com/mkg/value-stream/1.2.0> ;
  owl:versionInfo "1.2.0" .

vs:ValueStreamMetric a owl:Class ; rdfs:subClassOf core:EnterpriseEntity ; rdfs:label "Value Stream Metric" .
vs:WIPBuffer a owl:Class ; rdfs:subClassOf core:Asset ; rdfs:label "WIP Buffer" .
vs:BottleneckRisk a owl:Class ; rdfs:subClassOf vs:ValueStreamMetric ; rdfs:label "Bottleneck Risk" .
vs:BottleneckAssessment a owl:Class ; rdfs:subClassOf vs:ValueStreamMetric ; rdfs:label "Bottleneck Assessment" .

vs:contributesTo a owl:ObjectProperty ; rdfs:domain vs:ValueStreamMetric ; rdfs:range core:EnterpriseEntity ; rdfs:label "contributes to" .
vs:affectsFlow a owl:ObjectProperty ; rdfs:domain core:EnterpriseEntity ; rdfs:range core:EnterpriseEntity ; rdfs:label "affects flow" .
vs:metricValue a owl:DatatypeProperty ; rdfs:domain vs:ValueStreamMetric ; rdfs:range xsd:decimal ; rdfs:label "metric value" .
vs:unit a owl:DatatypeProperty ; rdfs:domain vs:ValueStreamMetric ; rdfs:range xsd:string ; rdfs:label "unit" .
vs:asOf a owl:DatatypeProperty ; rdfs:domain vs:ValueStreamMetric ; rdfs:range xsd:dateTime ; rdfs:label "as of" .
