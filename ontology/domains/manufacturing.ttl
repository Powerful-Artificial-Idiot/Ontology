@prefix core: <https://example.com/mkg/core#> .
@prefix mfg: <https://example.com/mkg/manufacturing#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/mkg/manufacturing> a owl:Ontology ;
  owl:imports <https://example.com/mkg/core> ;
  owl:versionIRI <https://example.com/mkg/manufacturing/1.1.0> ;
  owl:versionInfo "1.1.0" .

mfg:Product a owl:Class ; rdfs:subClassOf core:Asset ; rdfs:label "Product" .
mfg:ProductDefinition a owl:Class ; rdfs:subClassOf core:VersionedEntity ; rdfs:label "Product Definition" .
mfg:ProductInstance a owl:Class ; rdfs:subClassOf mfg:Product ; rdfs:label "Product Instance" .
mfg:Operation a owl:Class ; rdfs:subClassOf core:Process ; rdfs:label "Operation" .
mfg:OperationDefinition a owl:Class ; rdfs:subClassOf core:VersionedEntity ; rdfs:label "Operation Definition" .
mfg:OperationExecution a owl:Class ; rdfs:subClassOf core:Event ; rdfs:label "Operation Execution" .
mfg:ManufacturingResource a owl:Class ; rdfs:subClassOf core:Asset ; rdfs:label "Manufacturing Resource" .
mfg:Machine a owl:Class ; rdfs:subClassOf mfg:ManufacturingResource ; rdfs:label "Machine" .
mfg:ProcessParameter a owl:Class ; rdfs:subClassOf core:VersionedEntity ; rdfs:label "Process Parameter" .
mfg:Material a owl:Class ; rdfs:subClassOf core:Asset ; rdfs:label "Material" .
mfg:ProductionOrder a owl:Class ; rdfs:subClassOf core:EnterpriseEntity ; rdfs:label "Production Order" .

mfg:requiresOperation a owl:ObjectProperty ; rdfs:domain mfg:Product ; rdfs:range mfg:Operation ; rdfs:label "requires operation" .
mfg:executedBy a owl:ObjectProperty ; rdfs:domain mfg:Operation ; rdfs:range mfg:Machine ; rdfs:label "executed by" .
mfg:usesParameter a owl:ObjectProperty ; rdfs:domain mfg:Operation ; rdfs:range mfg:ProcessParameter ; rdfs:label "uses parameter" .
mfg:requiresResource a owl:ObjectProperty ; rdfs:domain mfg:Operation ; rdfs:range mfg:ManufacturingResource ; rdfs:label "requires resource" .
mfg:produces a owl:ObjectProperty ; rdfs:domain mfg:Operation ; rdfs:range core:Asset ; rdfs:label "produces" .
mfg:flowsTo a owl:ObjectProperty ; rdfs:domain core:EnterpriseEntity ; rdfs:range core:EnterpriseEntity ; rdfs:label "flows to" .
mfg:executesDefinition a owl:ObjectProperty ; rdfs:domain mfg:OperationExecution ; rdfs:range mfg:OperationDefinition ; rdfs:label "executes definition" .
mfg:eventTime a owl:DatatypeProperty ; rdfs:domain mfg:OperationExecution ; rdfs:range xsd:dateTime ; rdfs:label "event time" .
mfg:cycleTimeSeconds a owl:DatatypeProperty ; rdfs:domain mfg:Operation ; rdfs:range xsd:decimal ; rdfs:label "cycle time seconds" .
