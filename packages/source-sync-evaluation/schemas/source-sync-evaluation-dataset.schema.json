{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/source-sync-evaluation/dataset.schema.json",
  "title": "SourceSyncEvaluationDataset",
  "type": "object",
  "required": ["datasetVersion", "datasetId", "description", "cases"],
  "properties": {
    "datasetVersion": { "const": "1.0.0" },
    "datasetId": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array", "minItems": 32,
      "items": {
        "type": "object",
        "required": ["caseId", "domain", "title", "probeId", "assertionIds"],
        "properties": {
          "caseId": { "type": "string", "minLength": 1 },
          "domain": { "enum": ["mes", "plm", "qms", "cross-source-recovery"] },
          "title": { "type": "string", "minLength": 1 },
          "probeId": { "type": "string", "minLength": 1 },
          "assertionIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "skip": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
