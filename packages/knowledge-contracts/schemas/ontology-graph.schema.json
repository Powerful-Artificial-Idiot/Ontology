{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/ontology-graph.schema.json",
  "title": "OntologyGraphResponse",
  "type": "object",
  "required": ["metadata", "classes", "properties", "relations"],
  "properties": {
    "metadata": { "type": "object", "required": ["contractVersion", "ontologyVersion", "dataVersion", "traceId", "generatedAt"] },
    "classes": { "type": "array", "items": { "$ref": "#/$defs/class" } },
    "properties": { "type": "array", "items": { "$ref": "#/$defs/property" } },
    "relations": { "type": "array", "items": { "$ref": "knowledge-relation.schema.json" } }
  },
  "$defs": {
    "class": {
      "type": "object",
      "required": ["iri", "name", "label", "module"],
      "properties": {
        "iri": { "type": "string", "format": "uri" },
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "parentClasses": { "type": "array", "items": { "type": "string" } },
        "properties": { "type": "array", "items": { "type": "object", "required": ["iri"] } },
        "module": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "property": {
      "type": "object",
      "required": ["iri", "name", "label", "propertyType"],
      "properties": {
        "iri": { "type": "string", "format": "uri" },
        "name": { "type": "string" },
        "label": { "type": "string" },
        "propertyType": { "enum": ["object", "datatype"] },
        "domain": { "type": "array", "items": { "type": "string" } },
        "range": { "type": "array", "items": { "type": "string" } },
        "inverseOf": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
