{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/semantic-catalog.schema.json",
  "title": "SemanticCatalogResponse",
  "type": "object",
  "required": ["metadata", "lanes", "concepts", "entities", "mappings"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["contractVersion", "ontologyVersion", "dataVersion", "traceId", "generatedAt"],
      "properties": {
        "contractVersion": { "type": "string" },
        "ontologyVersion": { "type": "string" },
        "dataVersion": { "type": "string" },
        "traceId": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "description"],
        "properties": {
          "id": { "enum": ["business", "ontology", "system", "evidence", "ai"] },
          "label": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "primaryTermId", "title", "domain", "summary", "entityIds", "mappingIds", "aiContext"],
        "properties": {
          "id": { "type": "string" },
          "primaryTermId": { "type": "string" },
          "title": { "type": "string" },
          "domain": { "type": "string" },
          "summary": { "type": "string" },
          "entityIds": { "type": "array", "items": { "type": "string" } },
          "mappingIds": { "type": "array", "items": { "type": "string" } },
          "aiContext": {
            "type": "object",
            "required": ["resolvedMeaning", "relevantObjects", "availableActions", "promptContext", "evidenceCoverage"]
          }
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "conceptId", "label", "type", "domain", "description"],
        "properties": {
          "id": { "type": "string" },
          "conceptId": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string" },
          "domain": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "conceptId", "sourceId", "targetId", "relation", "label", "description"],
        "properties": {
          "id": { "type": "string" },
          "conceptId": { "type": "string" },
          "sourceId": { "type": "string" },
          "targetId": { "type": "string" },
          "relation": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
