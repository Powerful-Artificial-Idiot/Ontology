{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/connector-profile.schema.json",
  "title": "ConnectorProfileRegistry",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "version", "sourceSystem", "tenantId", "allowedDomains", "adapterType", "authentication", "synchronization", "mappingProfileId", "publicationPolicyId", "enabled"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "version": { "type": "string", "minLength": 1 },
      "sourceSystem": { "enum": ["mes", "plm", "qms"] },
      "tenantId": { "type": "string", "minLength": 1 },
      "allowedDomains": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
      "adapterType": { "enum": ["controlled-file", "fixture-http-json"] },
      "endpoint": {
        "type": "object",
        "required": ["baseUrl", "allowedPaths", "allowLocalhostHttp"],
        "properties": {
          "baseUrl": { "type": "string", "format": "uri" },
          "allowedPaths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^/" } },
          "allowLocalhostHttp": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "authentication": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["fixture-none", "static-bearer"] },
          "secretReference": { "type": "string", "pattern": "^MKG_SOURCE_SECRET_[A-Z0-9_]+$" }
        },
        "additionalProperties": false
      },
      "synchronization": {
        "type": "object",
        "required": ["mode", "pagination"],
        "properties": {
          "mode": { "enum": ["snapshot", "incremental"] },
          "pagination": { "enum": ["none", "page", "cursor", "watermark"] },
          "pageSize": { "type": "integer", "minimum": 1 },
          "maximumPages": { "type": "integer", "minimum": 1 },
          "maximumRecords": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      },
      "mappingProfileId": { "type": "string", "minLength": 1 },
      "publicationPolicyId": { "type": "string", "minLength": 1 },
      "enabled": { "type": "boolean" }
    },
    "additionalProperties": false
  }
}
