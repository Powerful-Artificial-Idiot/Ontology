{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/canonical-knowledge-baseline.schema.json",
  "title": "CanonicalKnowledgeBaseline",
  "type": "object",
  "required": ["baselineId", "baselineVersion", "agentContractVersion", "ontologyVersion", "dataVersion", "scenario", "ids", "entities", "relations", "request", "queryPlan", "graphQueryPlan", "evidencePack", "expectedResponse"],
  "properties": {
    "baselineId": { "type": "string", "minLength": 1 },
    "baselineVersion": { "type": "string", "minLength": 1 },
    "agentContractVersion": { "const": "1.0.0" },
    "ontologyVersion": { "type": "string", "minLength": 1 },
    "dataVersion": { "type": "string", "minLength": 1 },
    "scenario": {
      "type": "object",
      "required": ["id", "title", "question", "intent", "seedEntityIds"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "question": { "type": "string" },
        "intent": { "enum": ["quality_issue_trace", "quality_specification", "quality_control_threshold", "control_method_capability", "latest_quality_metric", "percentage_change_assessment", "value_limit_comparison", "reaction_plan", "measurement_system_capability", "program_change_status", "engineering_change_impact", "bottleneck_analysis", "evidence_lookup", "clarification_required"] },
        "supportedIntents": {
          "type": "array",
          "items": { "enum": ["quality_issue_trace", "quality_specification", "quality_control_threshold", "control_method_capability", "latest_quality_metric", "percentage_change_assessment", "value_limit_comparison", "reaction_plan", "measurement_system_capability", "program_change_status", "engineering_change_impact", "bottleneck_analysis", "evidence_lookup", "clarification_required"] },
          "uniqueItems": true
        },
        "seedEntityIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "ids": { "type": "object" },
    "semanticAliases": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "uniqueItems": true
      }
    },
    "entities": { "type": "array", "items": { "$ref": "https://example.com/mkg/contracts/knowledge-entity.schema.json" } },
    "relations": { "type": "array", "items": { "$ref": "https://example.com/mkg/contracts/knowledge-relation.schema.json" } },
    "request": { "$ref": "https://example.com/mkg/contracts/agent-turn-request.schema.json" },
    "queryPlan": { "$ref": "https://example.com/mkg/contracts/semantic-query-plan.schema.json" },
    "graphQueryPlan": { "$ref": "https://example.com/mkg/contracts/graph-query-plan.schema.json" },
    "evidencePack": { "$ref": "https://example.com/mkg/contracts/evidence-pack.schema.json" },
    "expectedResponse": { "$ref": "https://example.com/mkg/contracts/agent-turn-response.schema.json" }
  },
  "additionalProperties": false
}
