{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/agent-turn-response.schema.json",
  "title": "AgentTurnResponse",
  "type": "object",
  "required": ["contractVersion", "requestId", "turnId", "status", "queryPlan", "evidencePack", "answer", "citationValidation", "trace", "completedAt"],
  "properties": {
    "contractVersion": { "const": "1.0.0" },
    "requestId": { "type": "string", "minLength": 1 },
    "turnId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["completed", "clarification-required", "failed"] },
    "queryPlan": { "$ref": "https://example.com/mkg/contracts/semantic-query-plan.schema.json" },
    "graphQueryPlan": { "$ref": "https://example.com/mkg/contracts/graph-query-plan.schema.json" },
    "quantitativeAssessment": {
      "type": "object",
      "required": ["request", "assessments", "baselineDisclosureRequired"],
      "properties": {
        "request": {
          "type": "object",
          "required": ["characteristicId", "referencePolicy", "percentageChange"],
          "properties": {
            "characteristicId": { "type": "string", "minLength": 1 },
            "operationId": { "type": "string", "minLength": 1 },
            "productId": { "type": "string", "minLength": 1 },
            "referenceValue": { "type": "number" },
            "referenceMetricId": { "type": "string", "minLength": 1 },
            "referencePolicy": { "enum": ["explicit", "latest-governed-observation", "control-center-line", "compare-all-governed-baselines"] },
            "percentageChange": { "type": "number" }
          },
          "additionalProperties": false
        },
        "assessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assessmentId", "characteristicId", "referencePolicy", "referenceValue", "referenceUnit", "referenceSourceId", "referenceEvidenceIds", "percentageChange", "formula", "roundingPolicy", "projectedValue", "warningLimitStatus", "actionLimitStatus", "specificationStatus", "measurementCapabilityStatus", "productStatus", "comparisons", "requiredReactionPlanIds", "evidenceIds", "limitations"],
            "properties": {
              "assessmentId": { "type": "string", "minLength": 1 },
              "characteristicId": { "type": "string", "minLength": 1 },
              "operationId": { "type": "string", "minLength": 1 },
              "productId": { "type": "string", "minLength": 1 },
              "referencePolicy": { "enum": ["explicit", "latest-governed-observation", "control-center-line", "compare-all-governed-baselines"] },
              "referenceValue": { "type": "number" },
              "referenceUnit": { "type": "string", "minLength": 1 },
              "referenceSourceId": { "type": "string", "minLength": 1 },
              "referenceEvidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
              "percentageChange": { "type": "number" },
              "formula": { "type": "string", "minLength": 1 },
              "roundingPolicy": { "type": "string", "minLength": 1 },
              "projectedValue": { "type": "number" },
              "warningLimitStatus": { "enum": ["within", "exceeded", "unknown"] },
              "actionLimitStatus": { "enum": ["within", "exceeded", "unknown"] },
              "specificationStatus": { "enum": ["within", "at-limit", "exceeded", "unknown"] },
              "measurementCapabilityStatus": { "enum": ["measurable", "outside-range", "unknown"] },
              "productStatus": { "enum": ["conforming", "at-specification-limit", "nonconforming", "unknown"] },
              "comparisons": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["boundaryId", "boundaryType", "value", "unit", "status", "evidenceIds"],
                  "properties": {
                    "boundaryId": { "type": "string", "minLength": 1 },
                    "boundaryType": { "enum": ["warning-limit", "action-limit", "specification-upper-limit", "measurement-range-upper"] },
                    "value": { "type": "number" },
                    "unit": { "type": "string", "minLength": 1 },
                    "status": { "enum": ["within", "at-limit", "exceeded", "unknown"] },
                    "exceedance": { "type": "number" },
                    "relativeExceedancePercent": { "type": "number" },
                    "evidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
                  },
                  "additionalProperties": false
                }
              },
              "requiredReactionPlanIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
              "evidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
              "limitations": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "baselineDisclosureRequired": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "evidencePack": { "$ref": "https://example.com/mkg/contracts/evidence-pack.schema.json" },
    "answer": {
      "type": "object",
      "required": ["summary", "findings", "recommendedActions", "risks", "assumptions", "claims", "confidence"],
      "properties": {
        "summary": { "type": "string" },
        "findings": { "type": "array", "items": { "type": "string" } },
        "recommendedActions": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "confidence": { "enum": ["low", "medium", "high", "approved"] },
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "text", "classification", "citations"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "text": { "type": "string" },
              "classification": { "enum": ["fact", "assumption", "limitation", "unknown"] },
              "citations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["evidenceId"],
                  "properties": { "evidenceId": { "type": "string" }, "locator": { "type": "string" } },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "citationValidation": {
      "type": "object",
      "required": ["status", "checkedClaimIds", "issues"],
      "properties": {
        "status": { "enum": ["passed", "failed"] },
        "checkedClaimIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claimId", "code", "message"],
            "properties": {
              "claimId": { "type": "string" },
              "code": { "enum": ["missing-citation", "unknown-evidence", "unsupported-claim", "inactive-evidence", "ungoverned-evidence", "access-denied", "unknown-claim", "duplicate-claim", "missing-required-claim", "claim-classification-mismatch"] },
              "message": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "required": ["traceId", "requestId", "stages"],
      "properties": {
        "traceId": { "type": "string" },
        "requestId": { "type": "string" },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "stage", "status", "startedAt", "completedAt", "durationMs", "inputRefs", "outputRefs", "summary"],
            "properties": {
              "id": { "type": "string" },
              "stage": { "enum": ["semantic-parsing", "query-plan-validation", "ontology-validation", "query-compilation", "graph-retrieval", "document-retrieval", "quantitative-assessment", "evidence-pack", "answer-composition", "citation-validation"] },
              "status": { "enum": ["completed", "skipped", "failed"] },
              "startedAt": { "type": "string", "format": "date-time" },
              "completedAt": { "type": "string", "format": "date-time" },
              "durationMs": { "type": "number", "minimum": 0 },
              "tool": { "type": "string" },
              "inputRefs": { "type": "array", "items": { "type": "string" } },
              "outputRefs": { "type": "array", "items": { "type": "string" } },
              "summary": { "type": "string" },
              "errorCode": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "completedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
