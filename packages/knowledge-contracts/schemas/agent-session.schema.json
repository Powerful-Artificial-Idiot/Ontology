{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/agent-session.schema.json",
  "title": "AgentSession",
  "type": "object",
  "required": ["id", "contractVersion", "scenarioId", "mode", "language", "turnIds", "context", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "contractVersion": { "const": "1.0.0" },
    "scenarioId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["scripted", "live"] },
    "language": { "enum": ["zh", "en"] },
    "turnIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "context": {
      "type": "object",
      "required": ["previousTurnIds", "resolvedEntityIds", "assumptions"],
      "properties": {
        "previousTurnIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "resolvedEntityIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "activeTopic": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "security": { "$ref": "https://example.com/mkg/contracts/agent-session-security-context.schema.json" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
