{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/agent-turn-record.schema.json",
  "title": "AgentTurnRecord",
  "type": "object",
  "required": ["sessionId", "request", "response", "auditEventIds", "createdAt", "persistedAt"],
  "properties": {
    "sessionId": { "type": "string", "minLength": 1 },
    "request": { "$ref": "https://example.com/mkg/contracts/agent-turn-request.schema.json" },
    "response": { "$ref": "https://example.com/mkg/contracts/agent-turn-response.schema.json" },
    "auditEventIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "createdAt": { "type": "string", "format": "date-time" },
    "persistedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
