{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mkg/contracts/agent-turn-request.schema.json",
  "title": "AgentTurnRequest",
  "type": "object",
  "required": ["contractVersion", "requestId", "mode", "language", "message"],
  "properties": {
    "contractVersion": { "const": "1.0.0" },
    "requestId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "scenarioId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["scripted", "live"] },
    "language": { "enum": ["zh", "en"] },
    "message": { "type": "string", "minLength": 1 },
    "requestedAt": { "type": "string", "format": "date-time" },
    "context": {
      "type": "object",
      "required": ["previousTurnIds", "resolvedEntityIds", "assumptions"],
      "properties": {
        "previousTurnIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "resolvedEntityIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "activeTopic": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
