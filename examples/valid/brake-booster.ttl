@prefix core: <https://example.com/mkg/core#> .
@prefix demo: <https://example.com/mkg/demo#> .
@prefix equip: <https://example.com/mkg/equipment#> .
@prefix eng: <https://example.com/mkg/engineering#> .
@prefix mfg: <https://example.com/mkg/manufacturing#> .
@prefix qual: <https://example.com/mkg/quality#> .
@prefix vs: <https://example.com/mkg/value-stream#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

demo:MES a core:SourceSystem .

demo:BrakeBooster a mfg:Product ;
  mfg:requiresOperation demo:OP30 ;
  core:hasSource demo:MES ;
  core:sourceSystemId "FP-001" .

demo:OP30 a mfg:Operation ;
  mfg:executedBy demo:M220 ;
  mfg:cycleTimeSeconds 42.0 ;
  qual:controlsCharacteristic demo:LeakRate .

demo:OP30Execution001 a mfg:OperationExecution ;
  mfg:eventTime "2026-07-14T08:00:00Z"^^xsd:dateTime .

demo:M220 a mfg:Machine ;
  qual:associatedFailureMode demo:LeakageFailure ;
  equip:hasConfigurationVersion demo:M220ConfigV2 .

demo:LeakRate a qual:CriticalCharacteristic .
demo:LeakageFailure a qual:FailureMode ; qual:mayAffect demo:LeakRate .

demo:LeakResult001 a qual:MeasurementResult ;
  qual:numericValue 2.1 ;
  qual:unit "sccm" ;
  qual:measuresCharacteristic demo:LeakRate .

demo:CP001 a qual:ControlPlan ;
  qual:hasControlPlanVersion demo:CP001V2, demo:CP001V3 .

demo:CP001V2 a qual:ControlPlanVersion ;
  core:versionIdentifier "2" ;
  core:validFrom "2025-01-01"^^xsd:date ;
  core:validTo "2026-03-14"^^xsd:date ;
  qual:controlsCharacteristic demo:LeakRate .

demo:CP001V3 a qual:ControlPlanVersion ;
  core:versionIdentifier "3" ;
  core:validFrom "2026-03-15"^^xsd:date ;
  core:supersedes demo:CP001V2 ;
  qual:controlsCharacteristic demo:LeakRate .

demo:M220ConfigV1 a equip:MachineConfigurationVersion ;
  core:versionIdentifier "1" ;
  core:validFrom "2025-01-01"^^xsd:date ;
  core:validTo "2026-05-31"^^xsd:date .

demo:M220ConfigV2 a equip:MachineConfigurationVersion ;
  core:versionIdentifier "2" ;
  core:validFrom "2026-06-01"^^xsd:date ;
  core:supersedes demo:M220ConfigV1 .

demo:ProgramChangeV35 a eng:EngineeringChange ;
  eng:affects demo:M220, demo:OP30, demo:LeakRate ;
  eng:requiresValidation demo:ProgramValidationV35 ;
  eng:changeStatus "proposed" ;
  core:versionIdentifier "V3.5" ;
  core:validFrom "2026-07-22"^^xsd:date .

demo:ProgramValidationV35 a eng:ValidationRecord ;
  eng:releaseDecision "pending" .

demo:OP20 a mfg:Operation .
demo:OP20CycleTime a vs:ValueStreamMetric ;
  vs:contributesTo demo:OP20 ;
  vs:metricValue 48.0 ;
  vs:unit "seconds" .

demo:OP20BottleneckRisk a vs:BottleneckRisk ;
  vs:affectsFlow demo:OP20 ;
  vs:metricValue 0.82 ;
  vs:unit "ratio" .

demo:OP30RetestShiftRisk a vs:BottleneckRisk ;
  vs:affectsFlow demo:OP30 ;
  vs:metricValue 0.4 ;
  vs:unit "bounded-score" .

# Synthetic governed rich-demo facts. These values are not production specifications.
demo:LeakRateSpecificationRevA a qual:Specification ;
  core:versionIdentifier "Rev.A" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  core:appliesToProduct demo:BrakeBooster ;
  core:appliesToOperation demo:OP30 ;
  core:appliesToCharacteristic demo:LeakRate ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" ;
  qual:hasSpecificationLimit demo:LeakRateLSL, demo:LeakRateUSL .

demo:LeakRateLSL a qual:SpecificationLimit ;
  core:versionIdentifier "Rev.A" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  qual:numericValue 0.00 ;
  qual:unit "sccm" ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:limitType "lower-specification-limit" ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" .

demo:LeakRateUSL a qual:SpecificationLimit ;
  core:versionIdentifier "Rev.A" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  qual:numericValue 0.30 ;
  qual:unit "sccm" ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:limitType "upper-specification-limit" ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" .

demo:LeakRateWarningLimit a qual:InternalControlLimit ;
  core:versionIdentifier "Rev.A" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  qual:numericValue 0.24 ;
  qual:unit "sccm" ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:limitType "warning-limit" ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" .

demo:LeakRateActionLimit a qual:InternalControlLimit ;
  core:versionIdentifier "Rev.A" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  qual:numericValue 0.27 ;
  qual:unit "sccm" ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:limitType "action-limit" ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" .

demo:LeakRate qual:hasInternalControlLimit demo:LeakRateWarningLimit, demo:LeakRateActionLimit ;
  qual:measuredBy demo:M220MeasurementSystem ;
  qual:controlledBy demo:AirDecayControlMethod ;
  qual:triggersReactionPlan demo:OP30ReactionPlan ;
  qual:hasMetricSeries demo:LeakRateWeeklySeries .

demo:AirDecayControlMethod a qual:ControlMethod ;
  qual:usesMeasurementSystem demo:M220MeasurementSystem ;
  qual:numericValue 0.50 ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:unit "sccm" .

demo:M220MeasurementSystem a qual:MeasurementSystem ;
  qual:unit "sccm" ;
  qual:numericValue 0.50 ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:calibratedBy demo:M220Calibration202607 ;
  qual:hasMsaStudy demo:M220MsaRevA .

demo:M220Calibration202607 a qual:CalibrationRecord ;
  core:versionIdentifier "2026-07" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" .

demo:M220MsaRevA a qual:MeasurementSystemAnalysis ;
  core:versionIdentifier "Rev.A" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  qual:numericValue 8.2 ;
  qual:unit "percent-of-tolerance" ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" .

demo:LeakRateWeeklySeries a qual:MetricSeries ;
  qual:hasObservation demo:LeakRateW29 .

demo:LeakRateW29 a qual:MetricObservation ;
  qual:numericValue 0.22 ;
  qual:unit "sccm" ;
  qual:aggregationType "weekly-mean" ;
  qual:observedPeriod "2026-W29" ;
  qual:measuresCharacteristic demo:LeakRate ;
  qual:observedAtOperation demo:OP30 ;
  qual:observedOnMachine demo:M220 .

demo:OP30ReactionPlan a qual:ReactionPlan ;
  core:versionIdentifier "Rev.A" ;
  core:validFrom "2026-07-01"^^xsd:date ;
  qual:approvalState "approved" ;
  qual:effectiveState "current" ;
  qual:hasAction demo:HoldLot, demo:VerifyMasterLeak, demo:QualityReleaseApproval .

demo:HoldLot a qual:ContainmentAction .
demo:VerifyMasterLeak a qual:CorrectiveAction .
demo:QualityReleaseApproval a qual:CorrectiveAction .

demo:LeakTestProgramV34 a mfg:ProcessParameter ;
  core:versionIdentifier "V3.4" ;
  core:validFrom "2026-01-01"^^xsd:date .

demo:LeakTestProgramV35 a mfg:ProcessParameter ;
  core:versionIdentifier "V3.5" ;
  core:validFrom "2026-07-22"^^xsd:date .

demo:ProgramChangeV35 eng:affects demo:LeakTestProgramV35 ;
  eng:requiresValidation demo:ProgramValidationV35 ;
  eng:changeStatus "proposed" .

demo:ProgramValidationV35 eng:releaseDecision "pending" .
