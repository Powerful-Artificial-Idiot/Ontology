# local uses the in-process MockKnowledgeRepository; http uses the independent API.
VITE_KNOWLEDGE_MODE=local
VITE_KNOWLEDGE_API_BASE_URL=http://127.0.0.1:4174/api
VITE_KNOWLEDGE_TIMEOUT_MS=5000

# Agent Workspace defaults to scripted; api calls the local deterministic Agent API.
VITE_AGENT_MODE=scripted
VITE_AGENT_API_BASE_URL=http://127.0.0.1:4175/api/agent
VITE_AGENT_TIMEOUT_MS=12000
# Only for a controlled static-token acceptance environment. Do not embed long-lived enterprise credentials.
VITE_AGENT_API_TOKEN=

# Phase 5C security. Production profile fails startup when authentication is disabled.
MKG_AGENT_SECURITY_PROFILE=development
MKG_AGENT_AUTH_MODE=disabled
MKG_AGENT_AUTH_STATIC_TOKEN=
MKG_AGENT_AUTH_PRINCIPAL_ID=
MKG_AGENT_AUTH_TENANT_ID=
MKG_AGENT_AUTH_ROLE_IDS=agent-operator,agent-evidence-reader
MKG_AGENT_AUTH_DOMAIN_IDS=quality,production,engineering,value-stream
MKG_AGENT_AUTH_OBJECT_IDS=

# Server-only Agent knowledge repository configuration. Never prefix credentials with VITE_.
MKG_AGENT_KNOWLEDGE_MODE=mock
MKG_NEO4J_URI=bolt://127.0.0.1:7687
MKG_NEO4J_USERNAME=neo4j
MKG_NEO4J_PASSWORD=
MKG_NEO4J_DATABASE=neo4j

# Agent run/session persistence. Use memory only for isolated tests.
MKG_AGENT_STORE_MODE=file
MKG_AGENT_STORE_PATH=.data/agent-store.json
MKG_AGENT_RUN_TIMEOUT_MS=60000

# Local-first redacted observability. Set off to disable JSONL telemetry.
MKG_AGENT_TELEMETRY_MODE=jsonl
MKG_AGENT_TELEMETRY_PATH=.data/agent-telemetry.jsonl

# Server-only semantic parser. Deterministic remains the safe default.
MKG_AGENT_SEMANTIC_PARSER_MODE=deterministic
MKG_LLM_PROVIDER=openai
MKG_LLM_MODEL=
MKG_OPENAI_API_KEY=
MKG_OPENAI_BASE_URL=https://api.openai.com/v1
MKG_DEEPSEEK_API_KEY=
MKG_DEEPSEEK_BASE_URL=https://api.deepseek.com
MKG_DEEPSEEK_MODEL=deepseek-v4-flash
MKG_LLM_TIMEOUT_MS=20000

# Evidence-grounded answer generation. Template remains the safe default.
MKG_AGENT_ANSWER_COMPOSER_MODE=template
MKG_AGENT_DOCUMENT_MODE=governed
MKG_DOCUMENT_REGISTRY_PATH=packages/demo-data/documents/leak-rate/document-registry.json
MKG_DOCUMENT_PRINCIPAL_ID=demo-agent-service
MKG_DOCUMENT_ROLE_IDS=agent-evidence-reader
MKG_DOCUMENT_DOMAIN_IDS=quality,manufacturing,engineering
MKG_LLM_ANSWER_MODEL=
MKG_DEEPSEEK_ANSWER_MODEL=
MKG_LLM_ANSWER_TIMEOUT_MS=30000

# Versioned Agent evaluation and provider acceptance artifacts.
MKG_EVALUATION_DATASET_PATH=packages/demo-data/evaluations/leak-rate-quality-trace.v1.json
MKG_RELEASE_POLICY_PATH=packages/demo-data/evaluations/release-policy.v1.json
MKG_EVALUATION_REPORT_PATH=.data/evaluations/latest-report.json
MKG_PROVIDER_ACCEPTANCE_PATH=.data/evaluations/openai-provider-acceptance.json
MKG_EVALUATION_REPOSITORY_MODE=mock

# Phase 5D controlled-source acceptance. These paths contain derived local artifacts only.
MKG_SOURCE_SYNC_STORE_PATH=.data/source-sync/phase5d-acceptance-snapshot.json
MKG_SOURCE_SYNC_ACCEPTANCE_PATH=.data/evaluations/phase5d-source-sync-acceptance.json
