{
  "name": "manufacturing-graph-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:local": "VITE_KNOWLEDGE_MODE=local vite --host 0.0.0.0",
    "dev:http": "VITE_KNOWLEDGE_MODE=http VITE_KNOWLEDGE_API_BASE_URL=http://127.0.0.1:4174/api vite --host 0.0.0.0",
    "dev:agent": "VITE_AGENT_MODE=api VITE_AGENT_API_BASE_URL=http://127.0.0.1:4175/api/agent vite --host 0.0.0.0",
    "build": "npm run typecheck && npm run build:frontend && npm run build:agent-api",
    "build:frontend": "vite build",
    "build:agent-api": "vite build --config vite.agent-api.config.ts",
    "build:release": "python3 scripts/build_release.py",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b && tsc -p tsconfig.backend.json",
    "lint": "eslint src packages services --max-warnings 0",
    "test": "vitest run",
    "test:agent-core": "vitest run tests/backend/deterministic-agent-pipeline.test.ts",
    "test:watch": "vitest",
    "api:dev": "vite-node services/mock-knowledge-api/start.ts",
    "agent-api:dev": "vite-node services/agent-api/start.ts",
    "agent-api:start": "npm run start:agent-api",
    "start:agent-api": "node dist-agent-api/server.mjs",
    "config:check": "node dist-agent-api/check-config.mjs",
    "frontend:secret-check": "bash scripts/deployment/check-frontend-secrets.sh",
    "deploy:check": "npm run frontend:secret-check && bash scripts/deployment/validate-templates.sh",
    "agent-api:neo4j": "MKG_AGENT_KNOWLEDGE_MODE=neo4j vite-node services/agent-api/start.ts",
    "agent-api:test": "vitest run tests/integration/agent-api.test.ts tests/frontend/api-agent-client.test.ts",
    "agent:evaluate": "vite-node services/agent-api/run-evaluation.ts",
    "phase5b:fixtures": "node scripts/build_phase5b_fixtures.mjs",
    "phase5b:acceptance": "vite-node services/agent-api/run-phase5b-acceptance.ts",
    "security:acceptance": "vite-node services/agent-api/run-security-acceptance.ts && vitest run tests/backend/agent-security-policy.test.ts tests/integration/agent-security-api.test.ts",
    "source-sync:acceptance": "vite-node services/agent-api/run-source-sync-acceptance.ts && vitest run tests/backend/source-system-synchronization.test.ts",
    "source-sync:list": "vite-node services/source-sync/cli.ts list",
    "source-sync:inspect": "vite-node services/source-sync/cli.ts inspect",
    "source-sync:run": "vite-node services/source-sync/cli.ts run",
    "source-sync:runs:list": "vite-node services/source-sync/cli.ts runs-list",
    "source-sync:checkpoint:inspect": "vite-node services/source-sync/cli.ts checkpoint-inspect",
    "source-sync:quarantine:list": "vite-node services/source-sync/cli.ts quarantine-list",
    "source-sync:quarantine:inspect": "vite-node services/source-sync/cli.ts quarantine-inspect",
    "source-sync:quarantine:replay": "vite-node services/source-sync/cli.ts quarantine-replay",
    "source-sync:reconcile": "vite-node services/source-sync/cli.ts reconcile",
    "source-sync:recover": "vite-node services/source-sync/cli.ts recover",
    "source-sync:api": "vite-node services/source-sync-api/start.ts",
    "source-sync:fixture": "vite-node services/source-sync-fixture/start.ts",
    "source-sync:fixture-live": "vite-node services/source-sync/run-fixture-live-acceptance.ts",
    "source-sync:formal": "vite-node services/source-sync/run-formal-acceptance.ts",
    "source-sync:formal-tests": "vitest run tests/backend/source-system-synchronization.test.ts tests/backend/source-sync-formal.test.ts tests/backend/source-sync-evaluation.test.ts tests/backend/neo4j-publication.test.ts tests/integration/source-sync-api.test.ts",
    "source-sync:release-gate": "npm run source-sync:acceptance && npm run source-sync:formal-tests && npm run source-sync:fixture-live && npm run source-sync:formal",
    "openai:acceptance": "vite-node services/agent-api/verify-openai-providers.ts",
    "deepseek:acceptance": "vite-node services/agent-api/verify-deepseek-provider.ts",
    "documents:verify": "vite-node services/agent-api/verify-documents.ts",
    "neo4j:up": "docker compose -f compose.neo4j.yml up -d",
    "neo4j:down": "docker compose -f compose.neo4j.yml down",
    "neo4j:seed": "vite-node services/agent-api/seed-neo4j.ts",
    "neo4j:verify": "vite-node services/agent-api/verify-neo4j.ts",
    "neo4j:test": "MKG_NEO4J_TEST=1 vitest run tests/integration/neo4j-live.test.ts",
    "neo4j:publication-test": "MKG_NEO4J_TEST=1 vitest run tests/integration/neo4j-publication-live.test.ts",
    "api:test": "vitest run tests/integration/mock-knowledge-api.test.ts",
    "validate": "python3 scripts/validate_all.py",
    "validate:contracts": "python3 scripts/validate_demo_contracts.py",
    "validate:ontology": "python3 scripts/validate_ontology.py",
    "validate:shapes": "python3 scripts/validate_shapes.py",
    "validate:mappings": "python3 scripts/validate_mappings.py",
    "test:competency": "python3 scripts/run_competency_queries.py"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
