{
  "name": "manufacturing-graph-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:local": "VITE_KNOWLEDGE_MODE=local vite --host 0.0.0.0",
    "dev:http": "VITE_KNOWLEDGE_MODE=http VITE_KNOWLEDGE_API_BASE_URL=http://127.0.0.1:4174/api vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "build:release": "python3 scripts/build_release.py",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b",
    "lint": "eslint src packages services --max-warnings 0",
    "test": "vitest run",
    "test:agent-core": "vitest run tests/backend/deterministic-agent-pipeline.test.ts",
    "test:watch": "vitest",
    "api:dev": "vite-node services/mock-knowledge-api/start.ts",
    "api:test": "vitest run tests/integration/mock-knowledge-api.test.ts",
    "validate": "python3 scripts/validate_all.py",
    "validate:contracts": "python3 scripts/validate_demo_contracts.py",
    "validate:ontology": "python3 scripts/validate_ontology.py",
    "validate:shapes": "python3 scripts/validate_shapes.py",
    "validate:mappings": "python3 scripts/validate_mappings.py",
    "test:competency": "python3 scripts/run_competency_queries.py"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
